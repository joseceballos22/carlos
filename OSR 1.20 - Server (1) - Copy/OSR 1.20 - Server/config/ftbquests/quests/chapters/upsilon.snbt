		{
			dependencies: ["0E5632983BB97532"]
			description: ["Hostile Neural Networks is a mod based on Deep Mob Learning for 1.16.5 and higher. It allows you to train data models and run simulations, producing mob predictions, which can be used to generate mob loot."]
			id: "3082BB769BB97BEC"
			rewards: [
				{
					id: "1E457D1593BC3BCB"
					item: "chancecubes:chance_cube"
