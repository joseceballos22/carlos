craftingTable.addShapeless("red_snad", <item:snad:red_snad>, [<item:minecraft:red_sand>, <item:minecraft:red_sand>, <item:mysticalagradditions:insanium_essence>]);

craftingTable.addShapeless("suol_snad", <item:snad:suol_snad>, [<item:minecraft:soul_sand>, <item:minecraft:soul_sand>, <item:mysticalagradditions:insanium_essence>]);